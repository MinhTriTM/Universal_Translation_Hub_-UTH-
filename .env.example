# Universal Translation Hub (UTH) — Environment Variables
# Copy this file to .env and fill in your values

# ===== Xiaomi MiMo API =====
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.mimo.xiaomi.com/v1

# ===== MiMo Models =====
MIMO_MODEL_DIRECTOR=MiMo-V2.5-Pro
MIMO_MODEL_TRANSLATOR=MiMo-V2.5
MIMO_MODEL_OCR=MiMo-V2.5
MIMO_MODEL_TTS=MiMo-V2.5-TTS
MIMO_MODEL_VOICE_CLONE=MiMo-TTS-VoiceClone
MIMO_MODEL_VOICE_DESIGN=MiMo-TTS-VoiceDesign

# ===== Optional: Fallback APIs =====
# OPENAI_API_KEY=your_openai_key_here
# DEEPSEEK_API_KEY=your_deepseek_key_here
# GEMINI_API_KEY=your_gemini_key_here

# ===== Optional: Local TTS =====
# PIPER_MODEL_PATH=./models/piper/vi_VN-vais1000-medium.onnx
# MELO_MODEL_PATH=./models/melo/G_463000.pth

# ===== Optional: FFmpeg =====
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe

# ===== Optional: VLC =====
# VLC_HOST=localhost
# VLC_PORT=8080
# VLC_PASSWORD=your_vlc_password

# ===== Demo: Source Project Paths =====
# Override auto-detected paths for demo/setup.py
# MIMO_SOURCE_XIAOMI=D:\Du_An_Mini\XiaoMi100T
# MIMO_SOURCE_DICHGAME=E:\DichGame
# MIMO_SOURCE_MANGA=E:\DichGame\Tool\manga-image-translator

# ===== Logging =====
LOG_LEVEL=INFO
